---
import type { Lang } from '@/utils/i18n';
import PostCardCover from '@/cards/PostCardCover.astro';
import { t } from '@/utils/translations';
import { getPostsForLang, postUrl, type PostEntry } from '@/utils/posts';

interface Props {
  lang: Lang;
  limit?: number;
  showTitle?: boolean;
  class?: string;
}

const { lang, limit = 3, showTitle = true, class: className } = Astro.props as Props;

const posts = getPostsForLang(lang).slice(0, limit);
---

{
  posts.length > 0 && (
    <section class={`mt-10 ${className ?? ''}`.trim()}>
      {showTitle && <h2 class="sr-only">{t(lang, 'homepage.latestArticles')}</h2>}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 md:grid-cols-3">
        {posts.map((p) => (
          <PostCardCover
            href={postUrl(p as PostEntry, lang)}
            imageSrc={p.data.heroImage}
            imageAlt={p.data.heroImageAlt}
            title={p.data.title}
            date={p.data.pubDate}
            category={p.data.category}
            lang={lang}
          />
        ))}
      </div>
    </section>
  )
}
