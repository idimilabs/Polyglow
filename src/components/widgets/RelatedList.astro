---
import type { Lang } from '@/utils/i18n';
import PostCardCover from '@/cards/PostCardCover.astro';
import { t } from '@/utils/translations';
import { getRelatedPosts, postUrl, type PostEntry } from '@/utils/posts';

interface Props {
  lang: Lang;
  category: string;
  excludeId?: string;
  limit?: number;
  showTitle?: boolean;
}

const { lang, category, excludeId, limit = 3, showTitle = true } = Astro.props as Props;

const posts = getRelatedPosts(lang, category, excludeId, limit);
---

{
  posts.length > 0 && (
    <section class="mt-10">
      {showTitle && <h2 class="sr-only">{t(lang, 'post.relatedPosts')}</h2>}
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-3">
        {posts.map((p) => (
          <PostCardCover
            href={postUrl(p as PostEntry, lang)}
            imageSrc={p.data.heroImage}
            imageAlt={p.data.heroImageAlt}
            title={p.data.title}
            date={p.data.pubDate}
            category={p.data.category}
            lang={lang}
          />
        ))}
      </div>
    </section>
  )
}
